---
import { asset } from "@/lib/url";

const views = [
  {
    label: "Perspective 3D",
    title: "Sculpt the trajectory in space",
    body: "A wireframe HRTF sphere centres the listener head. Keyframes drop on the sphere surface, the orange path threads them in time order, and orbit controls let you read the motion from any angle.",
    image: "sferic-3d.png",
    alt: "3D perspective view of the unit sphere with the listener head at the centre and a chain of numbered keyframes connected by an orange trajectory line",
  },
  {
    label: "Top + side 2D",
    title: "Precise editing on two axes",
    body: "Drop into orthographic top (X/Z) and side (Z/Y) projections, both editable at once. Numbered keyframes stay in sync across views; snap angles, zoom, and per-view lock keep edits surgical.",
    image: "sferic-2d.png",
    alt: "Two side-by-side 2D orthographic views showing the same keyframe layout from above and from the side, with subtle dotted background grids and concentric reference circles",
  },
];
---

<section id="showcase" class="border-t border-[var(--border-subtle)] bg-[var(--bg-panel)]">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="mb-14">
      <span class="text-[11px] font-mono tracking-widest uppercase text-[var(--accent)]">Showcase</span>
      <h2 class="text-3xl md:text-4xl font-light tracking-tight mt-3 max-w-2xl">
        Designed like a tool you'd actually want to use.
      </h2>
    </div>

    <div class="space-y-16 md:space-y-24">
      {views.map((v, i) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center ${i % 2 === 1 ? 'lg:[&>:first-child]:order-2' : ''}`}>
          <div class="space-y-4">
            <span class="inline-flex items-center gap-2 text-[10px] font-mono tracking-widest uppercase text-[var(--text-dim)]">
              <span class="w-1 h-1 rounded-full bg-[var(--accent)]"></span>
              {v.label}
            </span>
            <h3 class="text-2xl md:text-3xl font-light tracking-tight text-[var(--text-primary)]">
              {v.title}
            </h3>
            <p class="text-[14px] text-[var(--text-secondary)] leading-relaxed max-w-md">
              {v.body}
            </p>
          </div>
          <div class="relative">
            <div class="absolute -inset-4 bg-gradient-to-tr from-[var(--accent-soft)]/30 via-transparent to-[var(--listener)]/15 blur-2xl opacity-60" aria-hidden></div>
            <div class="relative rounded-lg border border-[var(--border-strong)] overflow-hidden shadow-xl bg-[var(--bg-base)]">
              <div class="absolute top-0 left-0 right-0 h-6 bg-[var(--bg-panel-elev)] border-b border-[var(--border-subtle)] flex items-center gap-1.5 px-2.5 z-10">
                <span class="w-2 h-2 rounded-full bg-[#ff5f57]"></span>
                <span class="w-2 h-2 rounded-full bg-[#febc2e]"></span>
                <span class="w-2 h-2 rounded-full bg-[#28c840]"></span>
              </div>
              <img
                src={asset(v.image)}
                alt={v.alt}
                class="w-full block pt-6"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
