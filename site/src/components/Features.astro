---
const features = [
  {
    title: "HRTF binaural panning",
    body: "PannerNode in HRTF mode delivers immersive, head-related stereo from any position around the listener — fully realtime, sample-accurate.",
    icon: "headphones",
  },
  {
    title: "Visual 3D keyframing",
    body: "Drop keyframes anywhere on a unit sphere. The trajectory is a smooth interpolated path through them, scrubbable, editable, undoable.",
    icon: "target",
  },
  {
    title: "Two views, one mix",
    body: "Top (X/Z) and side (Z/Y) orthographic projections side-by-side, or a single perspective scene with orbit controls. Switch instantly.",
    icon: "layout",
  },
  {
    title: "Per-keyframe audio",
    body: "Each keyframe carries its own gain, low-pass, high-pass, doppler, air-absorption and reverb-send. Curves and tension per node.",
    icon: "sliders",
  },
  {
    title: "Realtime + offline render",
    body: "Audition with the live engine, then bounce to WAV (16/24/32-bit) or MP3 from the very same project file.",
    icon: "download",
  },
  {
    title: "Persisted projects",
    body: ".sferic.json — text-readable, versioned, diff-friendly. Reopen, share, drop on the window. Your audio gets re-linked automatically.",
    icon: "save",
  },
  {
    title: "Loop, snap, BPM",
    body: "Loop a region while you sculpt. Snap angles (5°, 15°, 30°…). BPM detection on the audio so keyframes can feel the grid.",
    icon: "loop",
  },
  {
    title: "Built for the desktop",
    body: "Tauri 2 + native menu bar + hardware-accelerated audio. ~10MB binary on macOS, Windows, Linux. Boots in under a second.",
    icon: "monitor",
  },
];

const ICONS: Record<string, string> = {
  headphones: '<path d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H4a1 1 0 0 1-1-1v-6Z"/><path d="M21 14h-3a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h2a1 1 0 0 0 1-1v-6Z"/><path d="M3 14a9 9 0 0 1 18 0"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  layout: '<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>',
  sliders: '<line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/>',
  download: '<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>',
  save: '<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/>',
  loop: '<polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>',
  monitor: '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
};
---

<section id="features" class="border-t border-[var(--border-subtle)]">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28">
    <div class="mb-14">
      <span class="text-[11px] font-mono tracking-widest uppercase text-[var(--accent)]">Features</span>
      <h2 class="text-3xl md:text-4xl font-light tracking-tight mt-3 max-w-2xl">
        A precision instrument for spatial audio,
        <span class="text-[var(--text-dim)]">not a toy.</span>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-[var(--border-subtle)] border border-[var(--border-subtle)] rounded-lg overflow-hidden">
      {features.map((f) => (
        <div class="bg-[var(--bg-panel)] p-6 hover:bg-[var(--bg-panel-elev)] transition-colors group">
          <div class="w-9 h-9 rounded-md bg-[var(--accent-soft)] flex items-center justify-center mb-4 group-hover:bg-[var(--accent)]/20 transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[f.icon]} />
          </div>
          <h3 class="text-[14px] font-medium mb-2 text-[var(--text-primary)]">{f.title}</h3>
          <p class="text-[13px] text-[var(--text-secondary)] leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
