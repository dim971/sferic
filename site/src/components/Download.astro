---
const platforms = [
  {
    name: "macOS",
    arch: "Universal (Apple Silicon + Intel)",
    icon: "apple",
    href: "https://github.com/dim971/sferic/releases/latest",
  },
  {
    name: "Windows",
    arch: "x86_64 · MSI installer",
    icon: "windows",
    href: "https://github.com/dim971/sferic/releases/latest",
  },
  {
    name: "Linux",
    arch: "AppImage · .deb · .rpm",
    icon: "linux",
    href: "https://github.com/dim971/sferic/releases/latest",
  },
];

const ICONS: Record<string, string> = {
  apple: '<path d="M16.5 2.5c-.5 1-1.5 1.8-2.5 2.2-.1-1.2.4-2.4 1-3.2.6-.8 1.7-1.4 2.6-1.5.1 1 .1 2-.1 2.5z"/><path d="M19 15.5c-.5 1.5-1.2 2.9-2 4-.7 1-1.4 2-2.5 2.1-1 0-1.4-.5-2.5-.5-1.2 0-1.6.5-2.6.5-1.1 0-1.9-1.1-2.6-2-1.4-2-2.5-5.6-1-8.1.7-1.2 2-2 3.3-2 1.1 0 2.1.7 2.7.7.6 0 1.9-.9 3.2-.7.6 0 2.1.2 3.1 1.7-2.7 1.6-2.3 5.2.9 4.3z"/>',
  windows: '<path d="M3 5.5L10.5 4.5V11.5H3V5.5z"/><path d="M11.5 4.4L21 3V11.5H11.5V4.4z"/><path d="M3 12.5H10.5V19.5L3 18.5V12.5z"/><path d="M11.5 12.5H21V21L11.5 19.6V12.5z"/>',
  linux: '<path d="M12 2c-1.5 0-3 1-3 3 0 .5.1 1 .3 1.5C8.5 7 8 8 8 9c0 .5.1 1 .2 1.5C7 12 6 13.5 6 15c0 2 1 3.5 2.5 4.5L8 21h8l-.5-1.5c1.5-1 2.5-2.5 2.5-4.5 0-1.5-1-3-2.2-4.5.1-.5.2-1 .2-1.5 0-1-.5-2-1.3-2.5.2-.5.3-1 .3-1.5 0-2-1.5-3-3-3z"/><circle cx="10" cy="6" r="0.5" fill="white"/><circle cx="14" cy="6" r="0.5" fill="white"/>',
};
---

<section id="download" class="border-t border-[var(--border-subtle)] bg-[var(--bg-panel)] hero-glow">
  <div class="max-w-6xl mx-auto px-6 py-20 md:py-28 relative">
    <div class="text-center mb-12">
      <span class="text-[11px] font-mono tracking-widest uppercase text-[var(--accent)]">Download</span>
      <h2 class="text-3xl md:text-4xl font-light tracking-tight mt-3 mb-4">
        Free. Open source. No account.
      </h2>
      <p class="text-[14px] text-[var(--text-secondary)] max-w-xl mx-auto">
        Builds are produced by GitHub Actions on every tagged release.
        v0.1 is the first usable cut — expect rough edges.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {platforms.map((p) => (
        <a
          href={p.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-lg border border-[var(--border-strong)] bg-[var(--bg-panel-elev)] hover:border-[var(--accent)] hover:bg-[var(--bg-input)] transition-all p-5 flex flex-col items-start gap-4"
        >
          <div class="w-10 h-10 rounded-md bg-[var(--bg-base)] border border-[var(--border-strong)] flex items-center justify-center group-hover:border-[var(--accent)] transition-colors">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="none" set:html={ICONS[p.icon]} />
          </div>
          <div class="flex-1">
            <div class="text-[15px] font-medium text-[var(--text-primary)] mb-1">{p.name}</div>
            <div class="text-[11px] font-mono text-[var(--text-dim)]">{p.arch}</div>
          </div>
          <div class="text-[11px] text-[var(--accent)] font-mono tracking-widest uppercase flex items-center gap-1.5">
            Releases page
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M7 17l9.2-9.2M17 17V7H7" />
            </svg>
          </div>
        </a>
      ))}
    </div>

    <div class="text-center mt-10 text-[12px] font-mono text-[var(--text-dim)]">
      Or build from source · <code class="text-[var(--text-secondary)]">git clone https://github.com/dim971/sferic && cd app && pnpm install && pnpm tauri build</code>
    </div>
  </div>
</section>
